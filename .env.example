# MatchMind Environment Variables
# Copy this to .env and fill in your keys

# LLM
GOOGLE_API_KEY=your_gemini_api_key_here

# Live match data (free at football-data.org)
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# MongoDB Atlas (free tier connection string)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/matchmind?retryWrites=true&w=majority

# Redis / Upstash (free tier)
REDIS_URL=redis://default:password@your-upstash-endpoint.upstash.io:6379

# App config
APP_ENV=development
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=30
